# 8-fold Brilliant Cut Diamond (钻石形,8边截面)
# 18 顶点 + 24 面 (8 冠部三角形 + 8 上腰四边形 + 8 亭部三角形)
# 比 PU_V8 原版 6顶点8面 更精致,更像真实切割钻石
# ★ 所有面转为退化四边形 (重复末顶点), 避免 WavefrontObject odd=true 延迟渲染污染
# ★ 每个顶点法线 = 顶点位置的归一化向量 (顶点法线 smooth shading)
o Diamond

# v1: 顶尖 (crown apex)
v 0.000000 1.000000 0.000000

# v2-v9: 上腰 (8 顶点, r=0.7, y=0.3, 每 45° 一个)
v 0.700000 0.300000 0.000000
v 0.494975 0.300000 0.494975
v 0.000000 0.300000 0.700000
v -0.494975 0.300000 0.494975
v -0.700000 0.300000 0.000000
v -0.494975 0.300000 -0.494975
v 0.000000 0.300000 -0.700000
v 0.494975 0.300000 -0.494975

# v10-v17: 下腰 (8 顶点, r=1.0, y=-0.6, 每 45° 一个)
v 1.000000 -0.600000 0.000000
v 0.707107 -0.600000 0.707107
v 0.000000 -0.600000 1.000000
v -0.707107 -0.600000 0.707107
v -1.000000 -0.600000 0.000000
v -0.707107 -0.600000 -0.707107
v 0.000000 -0.600000 -1.000000
v 0.707107 -0.600000 -0.707107

# v18: 底尖 (culet)
v 0.000000 -1.500000 0.000000

# 顶点法线 (顶点位置的归一化向量, Y分量也归一化)
vn 0.000000 1.000000 0.000000
vn 0.919145 0.393919 0.000000
vn 0.649721 0.393919 0.649721
vn 0.000000 0.393919 0.919145
vn -0.649721 0.393919 0.649721
vn -0.919145 0.393919 0.000000
vn -0.649721 0.393919 -0.649721
vn 0.000000 0.393919 -0.919145
vn 0.649721 0.393919 -0.649721
vn 0.857493 -0.514496 0.000000
vn 0.606339 -0.514496 0.606339
vn 0.000000 -0.514496 0.857493
vn -0.606339 -0.514496 0.606339
vn -0.857493 -0.514496 0.000000
vn -0.606339 -0.514496 -0.606339
vn 0.000000 -0.514496 -0.857493
vn 0.606339 -0.514496 -0.606339
vn 0.000000 -1.000000 0.000000

# 冠部三角形 (8 面): v1 + v_(2+i) + v_(3+i mod 8) (i=0..7)
# 退化四边形: 重复末顶点
f 1//1 2//2 3//3 3//3
f 1//1 3//3 4//4 4//4
f 1//1 4//4 5//5 5//5
f 1//1 5//5 6//6 6//6
f 1//1 6//6 7//7 7//7
f 1//1 7//7 8//8 8//8
f 1//1 8//8 9//9 9//9
f 1//1 9//9 2//2 2//2

# 上腰四边形 (8 面): v_(2+i) + v_(10+i) + v_(11+i mod 8) + v_(3+i mod 8)
f 2//2 10//10 11//11 3//3
f 3//3 11//11 12//12 4//4
f 4//4 12//12 13//13 5//5
f 5//5 13//13 14//14 6//6
f 6//6 14//14 15//15 7//7
f 7//7 15//15 16//16 8//8
f 8//8 16//16 17//17 9//9
f 9//9 17//17 10//10 2//2

# 亭部三角形 (8 面): v18 + v_(11+i mod 8) + v_(10+i)
# 退化四边形: 重复末顶点
f 18//18 11//11 10//10 10//10
f 18//18 12//12 11//11 11//11
f 18//18 13//13 12//12 12//12
f 18//18 14//14 13//13 13//13
f 18//18 15//15 14//14 14//14
f 18//18 16//16 15//15 15//15
f 18//18 17//17 16//16 16//16
f 18//18 10//10 17//17 17//17
