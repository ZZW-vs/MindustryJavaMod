# Triangular prism for prism turret (zzw mod)
# ★ 原版钻石形状 (PU_V8 prism.obj) - 6顶点 + 8三角形面
# ★ 退化四边形: 三角形面末顶点重复, 避免触发 WavefrontObject odd=true 延迟渲染污染
o Prism
v 1.000000 -1.000000 -1.000000
v 1.000000 -1.000000 1.000000
v 0.000000 1.000000 0.000000
v -1.000000 -1.000000 -1.000000
v -1.000000 -1.000000 1.000000
v 0.000000 -1.500000 0.000000
vn 0.0000 0.4472 0.8944
vn -0.8944 0.4472 0.0000
vn -0.4472 -0.8944 0.0000
vn 0.8944 0.4472 0.0000
vn 0.0000 0.4472 -0.8944
vn 0.0000 -0.8944 0.4472
vn 0.4472 -0.8944 0.0000
vn 0.0000 -0.8944 -0.4472
# 8 个三角形面 (转为退化四边形: 重复末顶点)
f 2//1 3//1 5//1 5//1
f 4//2 5//2 3//2 3//2
f 5//3 4//3 6//3 6//3
f 3//4 2//4 1//4 1//4
f 1//5 4//5 3//5 3//5
f 5//6 6//6 2//6 2//6
f 1//7 2//7 6//7 6//7
f 4//8 1//8 6//8 6//8
